# Database
DATABASE_USER=netweave
DATABASE_PASSWORD=securepassword
DATABASE_NAME=netweave_db
DATABASE_PORT=5432
DATABASE_URL="postgres://${DATABASE_USER}:${DATABASE_PASSWORD}@localhost:${DATABASE_PORT}/${DATABASE_NAME}"

# Default Users
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=adminpassword
DEFAULT_VIEWER_USER=viewer
DEFAULT_VIEWER_PASSWORD=viewerpassword

# OIDC (optional — all discovered automatically from issuer)
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=netweave
# OIDC_CLIENT_SECRET=your-secret
# OIDC_REDIRECT_URL=http://localhost:8789/auth/callback  # auto-derived if omitted

# Security
# Required in production. Generate with: openssl rand -hex 32
# Set NETWEAVE_ENV=dev to use an insecure development key instead.
# ENCRYPTION_KEY=<64-char hex string>
NETWEAVE_ENV=dev

# CORS — comma-separated list of allowed origins (empty = same-origin only)
# ALLOWED_ORIGINS=http://localhost:5173

# Session cookie — set to true when using HTTPS
# SESSION_SECURE_COOKIE=false

# Misc
RUST_LOG=debug
PORT=8789
